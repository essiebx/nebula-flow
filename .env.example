# --- Snowflake ---

SNOWFLAKE_ACCOUNT="YRXFULF-YSB19210"       # e.g. xy12345.us-east-1
SNOWFLAKE_USER="ESSIEBX"
SNOWFLAKE_PASSWORD=EW2bxS36Ar32Sgt
SNOWFLAKE_ROLE=ENGINEER_ROLE
SNOWFLAKE_WAREHOUSE=RETAIL_WH
SNOWFLAKE_DATABASE=RETAIL_DB
SNOWFLAKE_SCHEMA=BRONZE

# Snowpipe REST API (get from: SHOW PIPES IN SCHEMA RETAIL_DB.BRONZE)
SNOWPIPE_CLICKSTREAM_URL=https://<account>.snowflakecomputing.com/v1/data/pipes/<pipe_name>/insertFiles

# --- Kafka (Docker) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLICKSTREAM_TOPIC=retail.clickstream
KAFKA_CONSUMER_GROUP_ID=snowpipe-consumer-group

# --- Airflow ---
AIRFLOW_UID=50000                               # run: echo $(id -u) to get yours

# --- Alerts ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- Python ---
PYTHONPATH=.
